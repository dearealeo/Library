---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Ruleset">
  <div class="h">
    <h1>Ruleset</h1>
    <p><a href="/Library/">Back to Index</a></p>
  </div>

  <div class="c">
    <div class="w">
      <a href="/Library/ruleset/Clash/" class="b">Clash</a>
      <a href="/Library/ruleset/LegacyClashPremium/" class="b">Clash Premium</a>
      <a href="/Library/ruleset/Modules/" class="b">Modules</a>
      <a href="/Library/ruleset/sing-box/" class="b">Sing-Box</a>
      <a href="/Library/ruleset/List/" class="b">Surge</a>
    </div>
  </div>

  <div class="c">
    <h2>Disclaimer</h2>
    <p>
      This project employs publicly accessible ruleset excerpts sourced from <a
        href="https://github.com/SukkaW">@SukkaW</a
      > solely for non-commercial purposes, with all rights thereto reserved by <a
        href="https://github.com/SukkaW">@SukkaW</a
      >, and the definitive source for verification remains <a
        href="https://ruleset.skk.moe">ruleset.skk.moe</a
      >.
    </p>
  </div>
</BaseLayout>

<style>
  .h {
    margin-bottom: 30px;
  }

  .h a {
    text-decoration: none;
    color: var(--color-secondary);
    font-weight: 500;
    position: relative;
    transition: color 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    touch-action: manipulation;
    will-change: color, transform;
  }

  .h a:hover {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  .w {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }

  .b {
    padding: 12px 24px;
    text-decoration: none;
    color: var(--color-secondary);
    border-radius: 4px;
    font-size: 16px;
    will-change: transform, color, border-color;
    transform: translateZ(0);
    transition: color 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    user-select: none;
    border: 1px solid var(--color-secondary);
    display: inline-block;
  }

  .b:hover {
    color: var(--color-primary);
    transform: scale(1.1);
    border-color: var(--color-primary);
  }
</style>
